# Copy this file to .env and fill in your values before starting the project.
# The .env file is gitignored — never commit it.
#   cp .env.example .env

# =============================================================================
# Database
# =============================================================================

# SQLite database path (absolute path inside the Docker container).
# Default value works out of the box with docker compose.
# For local development without Docker, leave this unset — the backend falls
# back to ../data/qready.db relative to the backend/ directory.
DATABASE_URL=sqlite:////data/qready.db

# =============================================================================
# Agent
# =============================================================================

# Maximum time (seconds) the backend will wait for the agent subprocess to
# complete a scan before returning a timeout error. Default: 120
# AGENT_TIMEOUT=120

# When set to "true", the backend tells the agent to use fixture files instead
# of scanning the real machine. Set to "false" in production to run real scans.
# Default: true (safe for development — avoids triggering a real Windows scan)
# AGENT_TESTSET=true

# =============================================================================
# Backend (advanced)
# =============================================================================

# Log level for the FastAPI backend. Default: INFO
# Accepted values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# CORS allowed origins. Default allows the Vite dev server on localhost.
# Adjust in production to match your actual frontend domain.
# CORS_ORIGINS=http://localhost:5173

# =============================================================================
# Docker / Frontend proxy
# =============================================================================

# URL the Vite dev server (and nginx in prod) will proxy /api/* requests to.
# Defaults to http://backend:8000 when running inside Docker Compose.
# Override for local dev without Docker: API_TARGET=http://localhost:8000
# API_TARGET=http://backend:8000
